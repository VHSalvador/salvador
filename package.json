{
  "name": "portfolio-clone",
  "homepage": "https://www.salvador.hu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.js && vite build && (node scripts/prerender.js || true)",
    "lint": "eslint .",
    "preview": "vite preview",
